{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "#build/ui": ["./node_modules/@nuxt/ui/.nuxt/ui"],
      "@": ["./src"],
      "@/*": ["./src/*"],
      "#components": ["./src/components"],
      "#components/*": ["./src/components/*"],
      "#views": ["./src/views"],
      "#views/*": ["./src/views/*"],
      "#stores": ["./src/stores"],
      "#stores/*": ["./src/stores/*"],
      "#constants": ["./shared/constants"],
      "#constants/*": ["./shared/constants/*"],
      "#electron": ["./electron"],
      "#electron/*": ["./electron/*"]
    }
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
