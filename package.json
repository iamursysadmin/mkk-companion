{
  "name": "mkk-companion",
  "version": "1.0.0-dev",
  "main": "dist-electron/main/index.js",
  "description": "Companion app for Maschine and Komplete Kontrol by Native Instruments",
  "author": "iamursysadmin",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamursysadmin/mkk-companion.git"
  },
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue",
    "nuxt-ui",
    "vue-i18n",
    "vue-router"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:app": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm run build:app && playwright test",
    "test:e2e:update": "pnpm run build:app && playwright test --update-snapshots",
    "commitlint": "commitlint --edit",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,css,md}\"",
    "deps:check": "ncu --interactive",
    "changelog": "changelogen",
    "release:beta": "changelogen --release --clean --prerelease=beta",
    "release:stable": "changelogen --release --clean",
    "postinstall": "node node_modules/electron/install.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-vue": "6.0.8",
    "changelogen": "0.6.2",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.10.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "npm-check-updates": "22.2.9",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vite-plugin-electron": "1.1.0",
    "vite-plugin-electron-renderer": "1.0.0",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-tsc": "3.3.7"
  },
  "dependencies": {
    "@nuxt/ui": "4.10.0",
    "pathe": "2.0.3",
    "pinia": "4.0.2",
    "tonal": "6.4.3",
    "vue-i18n": "11.4.7",
    "vue-router": "5.2.0"
  }
}
